generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: connection URL lives in prisma.config.ts (see datasource block),
  // not here. The schema declares only the provider.
}

// ─── Users & Auth ─────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique  // also used as username for legacy accounts (kagon, acme, etc.)
  password  String?           // nullable — Google-OAuth users sign in without a local password
  role      String            // ADMIN | COMPANY | COURIER
  phone     String?
  active    Boolean  @default(true)
  // Auth-provider tracking. "credentials" = email+password sign-up. "google" = Google OAuth.
  // null for legacy seeded accounts (kagon, acme, peak, bob, charlie).
  provider  String?
  createdAt DateTime @default(now())

  // For COMPANY users — which Company they belong to
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  // Reverse relations
  assignedDeliveries  Delivery[]      @relation("CourierDeliveries")
  pickupDeliveries    Delivery[]      @relation("PickupDeliveries")
  importedBatches     ImportBatch[]
  notifications       Notification[]
  auditEntries        AuditLog[]
  inventoryItems      InventoryItem[] @relation("InventoryCreator")
}

// ─── Companies (senders) ──────────────────────────────────────────────────────

model Company {
  id        String   @id @default(cuid())
  name      String
  contact   String?  // contact name
  phone     String?
  email     String?
  address   String?
  active    Boolean  @default(true)

  // Excel upload approval gate.
  // Admin must set uploadEnabled = true before the company can submit imports.
  uploadEnabled     Boolean   @default(false)
  uploadRequestedAt DateTime?  // company sets this when requesting access; cleared on decision

  createdAt DateTime @default(now())

  users      User[]
  deliveries Delivery[]
  tariffs    Tariff[]
  imports    ImportBatch[]
  orders     Order[]
}

// ─── Tariffs (rate per company × zone) ────────────────────────────────────────

model Tariff {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  zone      String   // CAPITAL | REGION | MOUNTAIN
  amount    Float    @default(0)
  effective DateTime @default(now())
  note      String?

  @@unique([companyId, zone, effective])
}

// ─── Delivery ────────────────────────────────────────────────────────────────

model Delivery {
  id             String  @id @default(cuid())
  trackingNumber String  @unique

  // 8 PRD statuses
  status String @default("RECEIVED")
  // RECEIVED | IN_WAREHOUSE | ASSIGNED | IN_TRANSIT | DELIVERED | FAILED | REFUSED | RETURNED

  priority String @default("NORMAL")
  // LOW | NORMAL | HIGH | URGENT

  // Customer
  customerName  String
  customerPhone String
  customerEmail String?
  dropoffAddress String

  // Geographic location
  zone       String?  // region code — one of the 12 Georgian regions
  city       String?  // city / municipality name within the region
  postalCode String?  // 4-digit Georgian postal code — required at import time
  geoPlaceId String?  // optional link to the GeoPlace reference record

  // Package metadata
  packageType String?  // SMALL | MEDIUM | LARGE | FRAGILE | DOCUMENT
  weightKg    Float?   // package weight in kilograms — required at import time, nullable to back-fill old rows
  sizeCm      String?  // free-text dimensions in cm, e.g. "30x20x15"  — required at import time
  codAmount   Float?
  notes       String?
  problemFlag String?  // free-text problem reason if any

  // Sender
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  // Parent order — set on import-commit. Every parcel created by the importer
  // belongs to exactly one Order (one batch = one order). Nullable so legacy
  // rows created before this model existed don't break.
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  // Assignment — delivery courier (warehouse → customer)
  courierId String?
  courier   User?   @relation("CourierDeliveries", fields: [courierId], references: [id])

  // Pickup courier (sender → warehouse). The Excel files we ingest carry a
  // separate "აღმ. კურიერი" column for this person — they go to the company,
  // collect the parcel, and drop it off at our warehouse. Different from the
  // delivery courier who later takes it to the final recipient.
  pickupCourierId   String?
  pickupCourier     User?    @relation("PickupDeliveries", fields: [pickupCourierId], references: [id])
  pickupAssignedAt  DateTime?
  pickupCollectedAt DateTime?

  // Verification (warehouse step)
  verifiedAt   DateTime?
  verifiedNote String?

  // Proof of delivery
  proofNote     String?
  proofSignedBy String?

  // Courier comments per status update
  courierComment String?

  // Lifecycle timestamps
  pickedUpAt  DateTime?
  deliveredAt DateTime?
  failedAt    DateTime?
  refusedAt   DateTime?
  returnedAt  DateTime?

  history DeliveryHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([companyId])
  @@index([courierId])
  @@index([pickupCourierId])
  @@index([orderId])
}

model DeliveryHistory {
  id         String   @id @default(cuid())
  deliveryId String
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  status     String
  note       String?
  actorId    String?  // user id who triggered the change
  createdAt  DateTime @default(now())
}

// ─── Import Batches (Excel uploads from companies) ────────────────────────────

model ImportBatch {
  id          String   @id @default(cuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  uploadedBy  String?
  uploader    User?    @relation(fields: [uploadedBy], references: [id])
  filename    String?
  totalRows   Int      @default(0)
  importedRows Int     @default(0)
  errorRows   Int      @default(0)
  duplicateRows Int    @default(0)
  errorsJson  String?  // JSON array of error rows for review
  status      String   @default("DRAFT")  // DRAFT | COMMITTED | REJECTED
  createdAt   DateTime @default(now())
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String   // CREATE | UPDATE | DELETE | STATUS_CHANGE | TARIFF_CHANGE | LOGIN | etc.
  entity    String   // 'Delivery' | 'Company' | 'Tariff' | 'User' …
  entityId  String?
  before    String?  // JSON snapshot
  after     String?  // JSON snapshot
  note      String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([actorId])
}

// ─── Inventory ────────────────────────────────────────────────────────────────
// Lightweight stock tracker for the warehouse.
// Every change goes through audited server actions, so the per-item History
// panel can be reconstructed from AuditLog entries with entity='Inventory'.

model InventoryItem {
  id          String   @id @default(cuid())
  name        String
  sku         String?  @unique
  quantity    Int      @default(0)
  location    String?  // e.g. shelf / row / warehouse zone
  notes       String?

  createdById String?
  createdBy   User?    @relation("InventoryCreator", fields: [createdById], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  type      String   @default("INFO") // INFO | SUCCESS | WARNING | ERROR
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

// ─── Orders ───────────────────────────────────────────────────────────────────
// An Order represents one Excel batch that a company uploaded — a logical
// grouping of N parcels. The importer creates exactly one Order per commit
// and attaches every Delivery row from that file to it. Used as the
// "business / receipt" view of imports; lives at /admin/orders.

model Order {
  id            String   @id @default(cuid())
  // Sequential human-readable id, e.g. ORD-2026-0001
  orderNumber   String   @unique

  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])

  // Optional 1-1 link back to the import batch that created this order.
  importBatchId String?  @unique

  // Snapshot stats at create time. Updated as parcels move through the
  // lifecycle so the order summary can show real-time progress.
  parcelCount   Int      @default(0)
  totalValue    Float    @default(0)   // sum of codAmount across parcels

  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  deliveries    Delivery[]

  @@index([companyId])
}

// ─── Georgian geography (region → municipality → place) ───────────────────────
// Reference table for the Georgian administrative hierarchy. Used to power
// cascading region → city pickers and postal-code autocomplete in the importer
// and filters. `regionCode` is one of the 12 ZONES values.
//
// This table is also a bulk-import target: an official village-level CSV can be
// loaded into it later without touching application code.

model GeoPlace {
  id           String  @id @default(cuid())
  name         String                       // English name
  nameKa       String?                      // Georgian name
  type         String  @default("CITY")     // CITY | TOWN | VILLAGE | DISTRICT | MUNICIPALITY
  regionCode   String                       // one of the 12 region codes (zone)
  municipality String?                      // municipality this place sits in
  postalCode   String                       // 4-digit Georgian postal code

  createdAt    DateTime @default(now())

  @@index([regionCode])
  @@index([postalCode])
  @@index([name])
}
